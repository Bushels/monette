# Secrets / env
.env
.env.*
!.env.example

# GEE service-account JSON keys (can be downloaded into repo accidentally
# from a Cloud Console "Add Key" prompt). Real keys live at
# ~/.config/earthengine/monette-sa-key.json — outside the repo entirely.
*-sa-key.json
service-account-key.json
*-credentials.json

# Generated runtime config (template lives at config.template.js).
# Build script renders config.template.js -> config.js + public/config.js
# with MAPBOX_TOKEN substituted from env. Never commit the rendered file.
/config.js

# Vercel / Supabase / tool state
.vercel
.firecrawl/
.playwright-cli/
.claude/*
!.claude/
!.claude/agents/
!.claude/agents/**
!.claude/skills/
!.claude/skills/**
.claude/settings.local.json
.superpowers/

# Node
node_modules/
npm-debug.log*

# Build output
build/
output/
test-results/
dist/
public/
supabase/.temp/

# Logs
*.log

# Python build/cache artifacts. Producer pipeline (scripts/, tests/) is
# Python — these directories regenerate on every test/import and should
# never enter git history.
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Transient diagnostic / scratch scripts under scripts/gee_pipeline/ —
# the underscore-prefix convention marks one-off Codex/manual debug runs
# (e.g., _dist_check.py, _poll_t0.py, _rebuild_t0.py, _run_phase5.py).
# Real producer scripts live without the underscore.
scripts/gee_pipeline/_*.py

# Private content not published via this repo
# Deploys go directly via `vercel --prod` from local C:; these stay off GitHub.
docs/
!docs/
docs/*
# Exception: cleanup-journal is a tracked record of portfolio-state changes.
!docs/journal/
!docs/journal/**
# Exception: tracked methodology logs (seeding calibration, GEE QC, etc.).
!docs/logs/
!docs/logs/**
# but skip large machine-generated audit JSON (regenerates from scripts).
docs/logs/sk-titles/audit.json
dossiers/
_refs/
*.pdf

# Stray console-snippet files (Playwright eval residue)
JSON.stringify*
document.querySelector*

# OS / editor noise
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
