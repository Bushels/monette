# Copy to .env.local and fill in real values. .env.local is gitignored.

# Mapbox access token (public-scope only; flagged-scope tokens leak via the
# bundled config). Used by build-jsx.mjs to render config.js, and by
# scripts/build_creditors_data.py for geocoding lookups.
MAPBOX_TOKEN=pk.your_token_here

# Optional: set automatically by `vercel link` / `vercel env pull`. Short-lived.
# VERCEL_OIDC_TOKEN=
